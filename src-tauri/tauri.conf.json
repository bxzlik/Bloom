{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bloom",
  "version": "1.3.4",
  "identifier": "com.bloom.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bloom",
        "width": 1280,
        "height": 768,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      },
      {
        "label": "tray-popup",
        "url": "tray-popup.html",
        "title": "Bloom",
        "width": 300,
        "height": 290,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": true,
        "visible": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Bloom Overlay",
        "width": 420,
        "height": 104,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "shadow": false
      },
      {
        "label": "miniplayer",
        "url": "miniplayer.html",
        "title": "Bloom",
        "width": 300,
        "height": 320,
        "minWidth": 260,
        "minHeight": 300,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    },
    "withGlobalTauri": false
  },
  "plugins": {
    "deep-link": {
      "desktop": [
        {
          "schemes": ["bloom"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": ["icons/thumb/*.ico"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Russian", "English"]
      }
    },
    "fileAssociations": [
      {
        "ext": ["bloomplaylist"],
        "name": "Bloom Playlist",
        "description": "Bloom Playlist File",
        "role": "Editor"
      }
    ]
  }
}
